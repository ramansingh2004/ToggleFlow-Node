{
  "name": "@toggleflow/node",
  "version": "0.2.0",
  "description": "Official Node.js SDK for ToggleFlow feature flags",
  "author": "Raman Singh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramansingh2004/ToggleFlow-Node.git"
  },
  "homepage": "https://github.com/ramansingh2004/ToggleFlow-Node#readme",
  "bugs": {
    "url": "https://github.com/ramansingh2004/ToggleFlow-Node/issues"
  },
  "keywords": [
    "toggleflow",
    "feature-flags",
    "feature-toggle",
    "nodejs",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:package": "node tests/package-smoke.mjs",
    "check": "npm run check:version && npm run typecheck && npm test && npm run build && npm run test:package",
    "pack:check": "npm run check && npm pack --dry-run",
    "prepublishOnly": "npm run check",
    "check:version": "node scripts/verify-version.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
